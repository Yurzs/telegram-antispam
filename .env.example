# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Webhook mode (set to 'true' to enable webhooks, 'false' for polling)
WEBHOOK_MODE=false

# Webhook configuration (required if WEBHOOK_MODE=true)
# WEBHOOK_HOST=https://yourdomain.com
# WEBHOOK_PATH=/webhook
# WEBHOOK_PORT=8080
# WEBHOOK_SECRET=your_secret_token_here

# Optional: SOCKS5 proxy URL for connecting to the Telegram Bot API
# Supports socks5, socks4, and http proxy URLs
# PROXY_URL=socks5://user:password@host:port
